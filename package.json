    "@solana/buffer-layout-utils": "^0.3.0",
    "@zkprivacysol/sdk-core": "^0.1.12",
    "axios": "^1.13.4",
    "bs58": "^6.0.0",
    "circomlibjs": "^0.1.7",
    "commander": "^11.1.0",
    "node-fetch": "^2.7.0",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@types/chai": "^5.2.3",
    "@types/circomlibjs": "^0.1.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.11.0",
    "@types/node-fetch": "^2.6.13",
    "@types/snarkjs": "^0.7.9",
    "anchor-client-gen": "^0.28.1",
    "chai": "^4.3.4",
    "mocha": "^9.2.2",
    "prettier": "^2.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
