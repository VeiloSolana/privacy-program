{
  "scripts": {
    "build:anchor": "anchor build",
    "test:all": "mocha -r ts-node/register -t 1000000 'tests/**/*.test.ts'",
    "test:sol": "mocha -r ts-node/register -t 1000000 'tests/privacy-pool.test.ts'",
    "test:swap": "mocha -r ts-node/register -t 1000000 'tests/raydium-cpmm-swap.test.ts'",
    "test:amm": "mocha -r ts-node/register -t 1000000 'tests/raydium-amm-swap.test.ts'",
    "test:amm-usdt": "mocha -r ts-node/register -t 1000000 'tests/raydium-amm-swap-usdt.test.ts'",
    "test:amm-jup": "mocha -r ts-node/register -t 1000000 'tests/raydium-amm-swap-jup.test.ts'",
    "test:amm-usd1": "mocha -r ts-node/register -t 1000000 'tests/raydium-amm-swap-usd1.test.ts'",
    "test:amm-various": "mocha -r ts-node/register -t 1000000 'tests/raydium-amm-swap-various.test.ts'",
    "test:amm-various-jup": "mocha -r ts-node/register -t 1000000 'tests/raydium-amm-swap-various-jup.test.ts'",
    "test:spl": "mocha -r ts-node/register -t 1000000 'tests/privacy-pool-spl.test.ts'",
    "deploy:devnet": "ts-node scripts/deploy-devnet.ts",
    "check-pool": "ts-node scripts/check-pool.ts",
    "init-global-config": "ts-node scripts/initialize-global-config.ts",
    "update-global-config": "ts-node scripts/update-global-config.ts",
    "update-pool": "ts-node scripts/update-pool-config.ts",
    "clone-jupiter": "node scripts/clone-jupiter-route.js",
    "clone-jupiter:start": "node scripts/clone-jupiter-route.js --start",
    "setup-jupiter-env": "./scripts/setup-jupiter-test-env.sh",
    "test:jupiter-old": "ts-node scripts/test-jupiter-integration.ts",
    "test:jupiter": "mocha -r ts-node/register -t 1000000 'tests/jupiter-swap.test.ts'",
    "deploy:mainnet": "ts-node scripts/deploy-mainnet.ts",
    "deploy:mainnet:dry": "DRY_RUN=true ts-node scripts/deploy-mainnet.ts",
    "deploy:devnet:binary": "anchor deploy --provider.cluster devnet --program-keypair keys/program-keypair-devnet.json",
    "deploy:mainnet:binary": "anchor deploy --provider.cluster mainnet --program-keypair keys/program-keypair-mainnet.json",
    "keys:show": "node -e \"const fs=require('fs'),{Keypair}=require('@solana/web3.js'); ['admin','deployer','relayer','spl-relayer','program-keypair-devnet','program-keypair-mainnet'].forEach(n=>{try{const kp=Keypair.fromSecretKey(new Uint8Array(JSON.parse(fs.readFileSync('keys/'+n+'.json')))); console.log(n+':\\n  pub: '+kp.publicKey.toBase58());}catch(e){}});\"",
    "freeze:mainnet": "solana program set-upgrade-authority GYy4kM6GHhpgLCUscuABbzkD2ZbJ2fneYryaZ6Ch7fFU --final --keypair keys/program-keypair-mainnet.json --url mainnet-beta"
  },
  "dependencies": {
